# ============================================================
# Environment Configuration for Kinyan CRM
# ============================================================
# העתק קובץ זה ל-.env ומלא את הערכים המתאימים לסביבה שלך

# ── Database Configuration ──────────────────────────────
# PostgreSQL בלבד! (לא SQLite, לא MySQL)
# השתמש ב-postgresql+asyncpg:// (async driver)
# External URL עבור local/CI, Internal URL עבור Render services
DATABASE_URL=postgresql+asyncpg://crm_new_user:PASSWORD@dpg-XXXXX.frankfurt-postgres.render.com/crm_new

# ── Security Keys ────────────────────────────────────────
# מפתח ביטחון כללי למערכת - צור מחרוזת אקראית חזקה
# Python: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-string

# מפתח API עבור webhooks חיצוניים (Elementor, Yemot וכו')
API_KEY=webhook-secret-key-for-external-sources

# ── JWT Authentication ──────────────────────────────────
# JWT Secret Key - מפתח סודי לחתימת JWT tokens
# חייב להיות אותו מפתח בכל instances של השרת
# Python: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production

# אלגוריתם JWT (מומלץ HS256)
JWT_ALGORITHM=HS256

# זמן תוקף של JWT token בדקות (1440 = 24 שעות)
JWT_EXPIRATION_MINUTES=1440

# ── Google OAuth Setup ───────────────────────────────────
# הגדרת אימות Google OAuth 2.0
# 1. עבור ל-Google Cloud Console: https://console.cloud.google.com
# 2. צור פרויקט חדש או בחר קיים
# 3. הפעל את Google+ API
# 4. צור OAuth 2.0 Client ID (Web application)
# 5. הוסף Redirect URIs:
#    - Development: http://localhost:5173/auth/google/callback
#    - Production: https://your-domain.com/auth/google/callback

# Google Client ID (מתחיל ב-...apps.googleusercontent.com)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google Client Secret (מחרוזת ארוכה אקראית)
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Redirect URI עבור Google OAuth
# Development:
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback
# Production:
# GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

# ── Email SMTP Configuration ─────────────────────────────
# הגדרות שליחת מייל עבור איפוס סיסמאות ומיילים אוטומטיים
# 
# Gmail Setup:
# 1. הפעל 2-Factor Authentication בגוגל
# 2. עבור להגדרות אבטחה: https://myaccount.google.com/security
# 3. צור App Password: https://myaccount.google.com/apppasswords
# 4. השתמש ב-App Password (לא הסיסמה הרגילה)
#
# Outlook/Hotmail:
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
#
# SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key

# SMTP Server Host
SMTP_HOST=smtp.gmail.com

# SMTP Port (587 = STARTTLS, 465 = SSL/TLS)
SMTP_PORT=587

# SMTP Username (בדרך כלל כתובת המייל)
SMTP_USER=your-email@gmail.com

# SMTP Password (עבור Gmail: App Password, לא הסיסמה הרגילה!)
SMTP_PASSWORD=your-app-password

# From Email Address (כתובת השולח)
SMTP_FROM_EMAIL=your-email@gmail.com

# From Name (שם השולח שיוצג למקבל)
SMTP_FROM_NAME=Kinyan CRM

# ── Frontend Configuration ───────────────────────────────
# כתובת ה-Frontend עבור קישורים במיילים ו-CORS
# Development:
FRONTEND_URL=http://localhost:5173
# Production:
# FRONTEND_URL=https://your-domain.com

# ── Optional: Legacy Origami Integration ─────────────────
# אינטגרציה עם Origami (תקופת מעבר)
# רק אם אתה מעביר נתונים מ-Origami קיים

# Origami API URL
ORIGAMI_URL=https://kinyan-horaah.origami.ms/entities/api

# Origami Username
ORIGAMI_USERNAME=Info@kinyanhoraah.co.il

# Origami Secret Key (אם נדרש)
ORIGAMI_SECRET=

# ============================================================
# Development & Deployment Notes
# ============================================================
#
# Development Environment:
# - השתמש ב-localhost URLs
# - ניתן להשתמש ב-fake SMTP או Mailtrap לפיתוח
# - Google OAuth: הוסף http://localhost:5173 ל-authorized origins
#
# Production Environment:
# - השתמש בdomains אמיתיים
# - ודא ש-JWT_SECRET_KEY חזק ויחודי
# - השתמש בSMTP אמיתי (Gmail, SendGrid וכו')
# - הגדר SSL certificates
# - ודא ש-Google OAuth מוגדר עם הdomain הנכון
#
# Security Checklist:
# ✓ JWT_SECRET_KEY - מחרוזת ארוכה ואקראית
# ✓ SECRET_KEY - מחרוזת ארוכה ואקראית  
# ✓ Database credentials מאובטחים
# ✓ SMTP passwords (App Passwords, לא סיסמאות רגילות)
# ✓ Google OAuth secrets מאובטחים
# ✓ API_KEY למניעת גישה לא מורשית לwebhooks
#
# Environment Commands:
# Create .env file: cp .env.example .env
# Generate random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Test mail config: python -c "import smtplib; print('SMTP OK' if smtplib.SMTP('smtp.gmail.com', 587) else 'SMTP Error')"
